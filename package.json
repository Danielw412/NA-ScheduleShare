{
  "name": "na-scheduleshare",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "test": "vitest run",
    "test:function": "vitest run --config supabase/functions/schedule-import/vitest.config.ts && vitest run --config supabase/functions/delete-account/vitest.config.ts",
    "test:worker": "vitest run --config cloudflare/schedule-import-worker/vitest.config.ts",
    "test:watch": "vitest",
    "test:privacy": "supabase test db --local supabase/tests/database",
    "build": "tsc -b && vite build",
    "worker:typecheck": "tsc -p cloudflare/schedule-import-worker/tsconfig.json",
    "worker:diagnose": "node cloudflare/schedule-import-worker/diagnostic/run.mjs",
    "worker:dev": "wrangler dev --config cloudflare/schedule-import-worker/wrangler.toml",
    "worker:deploy": "wrangler deploy --config cloudflare/schedule-import-worker/wrangler.toml",
    "preview": "vite preview",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "types:generate": "supabase gen types typescript --local > src/lib/supabase/database.types.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.110.5",
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "supabase": "2.109.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "wrangler": "4.111.0"
  }
}
